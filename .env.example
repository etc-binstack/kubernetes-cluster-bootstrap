# =============================================================================
# K8S BOOTSTRAP CONFIGURATION - EXAMPLE FILE
# =============================================================================
# Copy this file to .env and customize for your environment
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Cluster Configuration
# -----------------------------------------------------------------------------

# Cluster deployment mode
# - single: Single control plane node (development/testing)
# - multi: Single control plane with multiple workers (small production)
# - ha: Multiple control plane nodes with load balancer (production HA)
CLUSTER_MODE=single

# Current node role
# - control-plane: Kubernetes control plane node (master)
# - worker: Kubernetes worker node
NODE_ROLE=control-plane

# HA Control Plane Settings (only for CLUSTER_MODE=ha)
# Enable HA mode for production environments requiring high availability
HA_MODE=false

# Number of control plane nodes (3, 5, or 7 recommended for HA)
# Odd numbers ensure proper etcd quorum
CONTROL_PLANE_COUNT=3

# IP addresses of all control plane nodes (comma-separated)
# Example: "10.0.1.10,10.0.1.11,10.0.1.12"
CONTROL_PLANE_IPS=""

# Load Balancer Configuration (required for HA)
# A load balancer is REQUIRED for HA control plane
# Options: HAProxy, NGINX, cloud LB (AWS ELB, Azure LB, GCP LB), or hardware LB
LOAD_BALANCER_ENABLED=false

# DNS name for the load balancer (recommended for production)
# Example: "k8s-api.example.com" or "k8s-lb.internal"
LOAD_BALANCER_DNS=""

# IP address of the load balancer
# Example: "10.0.1.100" or cloud LB VIP
LOAD_BALANCER_IP=""

# Port on load balancer that forwards to API servers (usually 6443)
LOAD_BALANCER_PORT=6443

# Control Plane Endpoint (auto-configured if load balancer is set)
# Format: "load-balancer-dns:6443" or "load-balancer-ip:6443"
# This will be auto-filled based on LOAD_BALANCER_DNS or LOAD_BALANCER_IP
CONTROL_PLANE_ENDPOINT=""

# -----------------------------------------------------------------------------
# Node Configuration
# -----------------------------------------------------------------------------

# Hostname for control plane node
# Will be set via hostnamectl during installation
CONTROL_PLANE_HOSTNAME=control-plane-01

# Hostname for worker nodes
# For multiple workers, use pattern like: node-01, node-02, etc.
WORKER_HOSTNAME=node-01

# Node scaling configuration
# Total number of nodes in cluster (control planes + workers) ⚠️ This does NOTHING! Documentation only,	Not used by scripts
NUMBER_OF_NODES=1

# Number of worker nodes already attached (increment as you add nodes) ⚠️ This does NOTHING! Documentation only,	Not used by scripts
ATTACHED_NODES=0

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------

# Pod network CIDR (internal pod IP range)
# Must not overlap with:
# - Your node network
# - Service CIDR
# - Any other networks you need to reach
# Common: 192.168.0.0/16 (Calico), 10.244.0.0/16 (Flannel)
POD_NETWORK_CIDR=192.168.0.0/16

# Service CIDR (ClusterIP service range)
# Must not overlap with pod network or node network
# Default Kubernetes: 10.96.0.0/12
SERVICE_CIDR=10.96.0.0/12

# CNI (Container Network Interface) plugin
# - calico: Full-featured, NetworkPolicy support, BGP routing
# - flannel: Simple overlay network, good for basic setups
# - cilium: eBPF-based, advanced security and observability
NETWORK_PLUGIN=calico

# Custom API Server Configuration
# IP address for API server to bind to (0.0.0.0 = all interfaces)
API_SERVER_BIND_ADDRESS=0.0.0.0

# Port for API server (default: 6443)
API_SERVER_BIND_PORT=6443

# API server advertise address (leave empty for auto-detect)
# Set this to node's primary IP if auto-detection fails
# Example: "10.0.1.10"
API_SERVER_ADVERTISE_ADDRESS=""

# DNS Configuration
# Kubernetes internal DNS domain for services
# Default: cluster.local
# Services will be accessible as: service-name.namespace.svc.cluster.local
CLUSTER_DNS_DOMAIN=cluster.local

# IP address for CoreDNS service (must be within SERVICE_CIDR)
# Default: 10.96.0.10
CLUSTER_DNS_IP=10.96.0.10

# Proxy Configuration (for air-gapped or corporate environments)
# Leave empty if direct internet access is available
HTTP_PROXY=""
HTTPS_PROXY=""

# Addresses that should bypass the proxy
NO_PROXY="localhost,127.0.0.1,10.0.0.0/8,192.168.0.0/16"

# -----------------------------------------------------------------------------
# Container Runtime
# -----------------------------------------------------------------------------

# Container runtime to use
# - containerd: Recommended, lightweight, CRI-native
# - cri-o: Alternative CRI-native runtime
CONTAINER_RUNTIME=containerd

# Cgroup driver (must match kubelet and container runtime)
# - systemd: Recommended for systems using systemd
# - cgroupfs: Legacy, not recommended for production
CGROUP_DRIVER=systemd

# -----------------------------------------------------------------------------
# Kubernetes Version
# -----------------------------------------------------------------------------

# Kubernetes version to install (major.minor format)
# Check available versions at: https://kubernetes.io/releases/
# Examples: 1.29, 1.30, 1.31
K8S_VERSION=1.29

# -----------------------------------------------------------------------------
# Certificate Configuration
# -----------------------------------------------------------------------------

# Certificate validity period in days
# Kubeadm default: 365 days
# Production recommendation: 365-730 days
CERT_VALIDITY_DAYS=365

# Renew certificates N days before expiry
# Allows time for validation and rollout
CERT_RENEW_BEFORE_DAYS=30

# Enable automatic certificate renewal
# When enabled, certificates will be renewed automatically
CERT_AUTO_RENEW=false

# External CA Configuration (Advanced)
# Use an external Certificate Authority instead of kubeadm's self-signed CA
# Required for compliance or integration with existing PKI
EXTERNAL_CA_ENABLED=false

# Path to external CA certificate (PEM format)
EXTERNAL_CA_CERT_PATH=""

# Path to external CA private key (PEM format)
EXTERNAL_CA_KEY_PATH=""

# Additional Subject Alternative Names (SANs) for API server certificate
# Add any additional IPs or DNS names that will be used to access the API
# Comma-separated list
# Example: "192.168.1.100,k8s.example.com,kubernetes.internal"
CERT_EXTRA_SANS=""

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# Encryption at Rest
# Encrypt secrets stored in etcd
# Recommended for: production, compliance requirements (PCI-DSS, HIPAA)
ENCRYPTION_AT_REST=false

# Base64-encoded encryption key (32 bytes for AES-CBC)
# Leave empty to auto-generate during setup
# Generate with: head -c 32 /dev/urandom | base64
ENCRYPTION_KEY=""

# Kubernetes Audit Logging
# Track all API server requests for security and compliance
AUDIT_LOG_ENABLED=false

# Path where audit logs will be stored
AUDIT_LOG_PATH=/var/log/kubernetes/audit.log

# Maximum days to retain audit logs
AUDIT_LOG_MAX_AGE=30

# Maximum number of old audit log files to retain
AUDIT_LOG_MAX_BACKUP=10

# Maximum size in MB before log rotation
AUDIT_LOG_MAX_SIZE=100

# -----------------------------------------------------------------------------
# Etcd Configuration
# -----------------------------------------------------------------------------

# Etcd Backup Configuration
# Automatic backups of etcd data (recommended for production)
ETCD_BACKUP_ENABLED=false

# Directory where etcd backups will be stored
ETCD_BACKUP_DIR=/var/lib/etcd-backup

# Number of days to retain etcd backups
ETCD_BACKUP_RETENTION_DAYS=7

# External Etcd Configuration (Advanced)
# Use external etcd cluster instead of stacked etcd
# Provides better isolation and scalability
EXTERNAL_ETCD_ENABLED=false

# Comma-separated list of etcd endpoints
# Example: "https://etcd1.example.com:2379,https://etcd2.example.com:2379,https://etcd3.example.com:2379"
EXTERNAL_ETCD_ENDPOINTS=""

# Path to etcd CA certificate
EXTERNAL_ETCD_CA_FILE=""

# Path to etcd client certificate
EXTERNAL_ETCD_CERT_FILE=""

# Path to etcd client key
EXTERNAL_ETCD_KEY_FILE=""

# -----------------------------------------------------------------------------
# Join Configuration
# -----------------------------------------------------------------------------

# Join command for worker nodes (auto-generated during control plane installation)
# The installation script automatically updates this field when initializing the control plane.
# You can copy this .env file to worker nodes to join them to the cluster.
# Format: kubeadm join <endpoint> --token <token> --discovery-token-ca-cert-hash sha256:<hash>
# Note: Join tokens expire after 24h by default. Regenerate with: kubeadm token create --print-join-command
JOIN_COMMAND=""

# Certificate key for joining additional control plane nodes (HA mode)
# Auto-generated during first control plane init with --upload-certs
CERTIFICATE_KEY=""

# -----------------------------------------------------------------------------
# SSH Configuration (for multi-node setup)
# -----------------------------------------------------------------------------

# SSH username for remote node access
SSH_USER=ubuntu

# Path to SSH private key
SSH_KEY=~/.ssh/id_rsa

# SSH port (default: 22)
SSH_PORT=22

# -----------------------------------------------------------------------------
# Advanced Configuration
# -----------------------------------------------------------------------------

# Kubernetes Feature Gates
# Enable experimental/alpha features
# Comma-separated list: "Feature1=true,Feature2=false"
# Example: "GracefulNodeShutdown=true,IPv6DualStack=true,TopologyAwareHints=true"
# See: https://kubernetes.io/docs/reference/command-line-tools-reference/feature-gates/
FEATURE_GATES=""

# Additional kubeadm arguments
# Pass extra flags to kubeadm init/join
# Example: "--skip-phases=addon/kube-proxy"
KUBEADM_EXTRA_ARGS=""

# Additional kubelet arguments
# Pass extra flags to kubelet
# Example: "--max-pods=110 --cpu-manager-policy=static"
KUBELET_EXTRA_ARGS=""

# Node Labels
# Comma-separated key=value pairs
# Example: "environment=production,zone=us-east-1a,instance-type=m5.large"
NODE_LABELS=""

# Node Taints
# Comma-separated taints in format: key=value:effect
# Effects: NoSchedule, PreferNoSchedule, NoExecute
# Example: "workload=special:NoSchedule,dedicated=gpu:NoExecute"
NODE_TAINTS=""

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Log level for bootstrap scripts
# debug: Verbose output for troubleshooting
# info: Standard informational messages (recommended)
# warn: Only warnings and errors
# error: Only errors
LOG_LEVEL=info

# Directory where bootstrap logs will be stored
LOG_DIR=/var/log/k8s-bootstrap

# Number of days to retain bootstrap logs
LOG_RETENTION_DAYS=30

# =============================================================================
# CONFIGURATION EXAMPLES FOR COMMON SCENARIOS
# =============================================================================

# -----------------------------------------------------------------------------
# Example 1: Single-Node Development Cluster
# -----------------------------------------------------------------------------
# CLUSTER_MODE=single
# NODE_ROLE=control-plane
# HA_MODE=false
# NETWORK_PLUGIN=calico
# POD_NETWORK_CIDR=192.168.0.0/16

# -----------------------------------------------------------------------------
# Example 2: Multi-Node Production Cluster (Single Control Plane)
# -----------------------------------------------------------------------------
# CLUSTER_MODE=multi
# NODE_ROLE=control-plane  # For first node, then switch to "worker"
# NUMBER_OF_NODES=4
# NETWORK_PLUGIN=calico

# -----------------------------------------------------------------------------
# Example 3: HA Production Cluster (3 Control Planes + Workers)
# -----------------------------------------------------------------------------
# CLUSTER_MODE=ha
# HA_MODE=true
# CONTROL_PLANE_COUNT=3
# CONTROL_PLANE_IPS="10.0.1.10,10.0.1.11,10.0.1.12"
# LOAD_BALANCER_ENABLED=true
# LOAD_BALANCER_DNS="k8s-api.example.com"
# LOAD_BALANCER_IP="10.0.1.100"
# CONTROL_PLANE_ENDPOINT="k8s-api.example.com:6443"
# CERT_EXTRA_SANS="10.0.1.100,k8s-api.example.com"

# -----------------------------------------------------------------------------
# Example 4: Air-Gapped Environment with Proxy
# -----------------------------------------------------------------------------
# HTTP_PROXY="http://proxy.corp.com:8080"
# HTTPS_PROXY="http://proxy.corp.com:8080"
# NO_PROXY="localhost,127.0.0.1,10.0.0.0/8,192.168.0.0/16,.corp.com"

# -----------------------------------------------------------------------------
# Example 5: Security-Hardened Cluster
# -----------------------------------------------------------------------------
# ENCRYPTION_AT_REST=true
# AUDIT_LOG_ENABLED=true
# CERT_VALIDITY_DAYS=365
# CERT_AUTO_RENEW=true
# ETCD_BACKUP_ENABLED=true

# =============================================================================
# END OF CONFIGURATION
# =============================================================================

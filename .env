# =============================================================================
# K8S BOOTSTRAP CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# Cluster Configuration
# -----------------------------------------------------------------------------
CLUSTER_MODE=single        # single | multi | ha
NODE_ROLE=control-plane    # control-plane | worker

# HA Control Plane Settings (only for CLUSTER_MODE=ha)
HA_MODE=false              # true | false
CONTROL_PLANE_COUNT=3      # Number of control plane nodes (3, 5, or 7 recommended)
CONTROL_PLANE_IPS=""       # Comma-separated IPs: "10.0.1.10,10.0.1.11,10.0.1.12"

# Load Balancer Configuration (required for HA)
LOAD_BALANCER_ENABLED=false
LOAD_BALANCER_DNS=""       # DNS name or VIP: "k8s-api.example.com"
LOAD_BALANCER_IP=""        # Load balancer IP address
LOAD_BALANCER_PORT=6443    # API server port on load balancer

# Control Plane Endpoint (auto-set if load balancer configured)
CONTROL_PLANE_ENDPOINT=""  # Format: "load-balancer-ip:6443" or "dns:6443"

# -----------------------------------------------------------------------------
# Node Configuration
# -----------------------------------------------------------------------------
CONTROL_PLANE_HOSTNAME=control-plane-01
WORKER_HOSTNAME=node-01

# Node scaling
NUMBER_OF_NODES=1
ATTACHED_NODES=0           # increment when adding workers

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
POD_NETWORK_CIDR=192.168.0.0/16
SERVICE_CIDR=10.96.0.0/12  # Kubernetes service CIDR
NETWORK_PLUGIN=calico      # calico | flannel | cilium | weave | none

# CNI Plugin Version (optional - uses latest stable if not specified)
CNI_VERSION=""             # Example: v3.27.0 for Calico, v1.15.0 for Cilium

# Calico-specific configuration
CALICO_IPV4POOL_CIDR=""    # Override default IPv4 pool (usually same as POD_NETWORK_CIDR)
CALICO_IP_IN_IP=false      # Enable IP-in-IP encapsulation
CALICO_VXLAN=false         # Enable VXLAN encapsulation

# Flannel-specific configuration
FLANNEL_BACKEND="vxlan"    # vxlan | host-gw | udp | wireguard

# Weave Net-specific configuration
WEAVE_ENCRYPTION=false     # Enable Weave Net encryption
WEAVE_PASSWORD=""          # Password for Weave Net encryption

# Custom API Server Configuration
API_SERVER_BIND_ADDRESS=0.0.0.0  # Default: listen on all interfaces
API_SERVER_BIND_PORT=6443        # Default API server port
API_SERVER_ADVERTISE_ADDRESS=""  # Leave empty for auto-detect

# DNS Configuration
CLUSTER_DNS_DOMAIN=cluster.local # Kubernetes cluster domain
CLUSTER_DNS_IP=10.96.0.10        # CoreDNS service IP (must be in SERVICE_CIDR)

# Proxy Configuration (optional)
HTTP_PROXY=""
HTTPS_PROXY=""
NO_PROXY="localhost,127.0.0.1,10.0.0.0/8,192.168.0.0/16"

# -----------------------------------------------------------------------------
# Container Runtime
# -----------------------------------------------------------------------------
CONTAINER_RUNTIME=containerd     # containerd | cri-o
CGROUP_DRIVER=systemd            # systemd | cgroupfs
CRIO_VERSION=""                  # CRI-O version (defaults to K8S_VERSION if empty)

# Registry Configuration
REGISTRY_MIRROR=""               # Container registry mirror (e.g., "https://mirror.gcr.io")

# -----------------------------------------------------------------------------
# Kubernetes Version
# -----------------------------------------------------------------------------
K8S_VERSION=1.29

# -----------------------------------------------------------------------------
# Certificate Configuration
# -----------------------------------------------------------------------------
# Certificate management
CERT_VALIDITY_DAYS=365           # Certificate validity period (default: 365)
CERT_RENEW_BEFORE_DAYS=30        # Renew certificates N days before expiry
CERT_AUTO_RENEW=false            # Enable automatic certificate renewal

# External CA (optional - leave empty to use kubeadm's CA)
EXTERNAL_CA_ENABLED=false
EXTERNAL_CA_CERT_PATH=""         # Path to CA certificate
EXTERNAL_CA_KEY_PATH=""          # Path to CA key

# Certificate SANs (Subject Alternative Names)
# Add additional IPs/DNS names for API server certificate
# IMPORTANT: Add your EC2 public IP here for remote kubectl access
CERT_EXTRA_SANS="YOUR_EC2_PUBLIC_IP"  # Comma-separated: "192.168.1.100,k8s.example.com"
# Example: CERT_EXTRA_SANS="3.6.192.28,my-cluster.example.com"

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Encryption at rest
ENCRYPTION_AT_REST=false         # Encrypt etcd data at rest
ENCRYPTION_KEY=""                # Base64 encoded encryption key (auto-generated if empty)

# Audit logging
AUDIT_LOG_ENABLED=false
AUDIT_LOG_PATH=/var/log/kubernetes/audit.log
AUDIT_LOG_MAX_AGE=30
AUDIT_LOG_MAX_BACKUP=10
AUDIT_LOG_MAX_SIZE=100

# -----------------------------------------------------------------------------
# Etcd Configuration
# -----------------------------------------------------------------------------
# Etcd backup
ETCD_BACKUP_ENABLED=false
ETCD_BACKUP_DIR=/var/lib/etcd-backup
ETCD_BACKUP_RETENTION_DAYS=7

# External etcd (optional - leave empty to use stacked etcd)
EXTERNAL_ETCD_ENABLED=false
EXTERNAL_ETCD_ENDPOINTS=""       # Comma-separated: "https://etcd1:2379,https://etcd2:2379"
EXTERNAL_ETCD_CA_FILE=""
EXTERNAL_ETCD_CERT_FILE=""
EXTERNAL_ETCD_KEY_FILE=""

# -----------------------------------------------------------------------------
# Join Configuration
# -----------------------------------------------------------------------------
# Join command (auto-filled by control plane)
JOIN_COMMAND=""
CERTIFICATE_KEY=""               # For joining additional control plane nodes (HA mode)

# -----------------------------------------------------------------------------
# SSH Configuration (for multi-node setup)
# -----------------------------------------------------------------------------
SSH_USER=ubuntu
SSH_KEY=~/.ssh/id_rsa
SSH_PORT=22

# Worker node addition configuration
NODES_FILE=scripts/nodes.txt      # Path to nodes file
PARALLEL_EXECUTION=false           # Parallel node addition (true | false)
MAX_RETRIES=3                      # Maximum retry attempts per node
RETRY_DELAY=10                     # Delay in seconds between retries
SSH_TIMEOUT=30                     # SSH connection timeout in seconds
POST_JOIN_WAIT=60                  # Wait time in seconds after join for verification

# -----------------------------------------------------------------------------
# Advanced Configuration
# -----------------------------------------------------------------------------
# Feature gates (comma-separated)
FEATURE_GATES=""                 # Example: "GracefulNodeShutdown=true,IPv6DualStack=true"

# Additional kubeadm arguments
KUBEADM_EXTRA_ARGS=""

# Kubelet extra arguments
KUBELET_EXTRA_ARGS=""

# Node labels (comma-separated key=value pairs)
NODE_LABELS=""                   # Example: "environment=production,zone=us-east-1a"

# Node taints (comma-separated)
NODE_TAINTS=""                   # Example: "key1=value1:NoSchedule,key2=value2:NoExecute"

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info                   # debug | info | warn | error
LOG_DIR=/var/log/k8s-bootstrap
LOG_RETENTION_DAYS=30